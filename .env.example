# === Telegram ===
BOT_TOKEN=YOUR_BOT_TOKEN              # Get from @BotFather
ALLOWED_USERS=                         # Empty = everyone, or comma-separated IDs: 123456,789012

# === STT Engine: "gemini" (fast, free) or "whisper" (offline, private) ===
STT_ENGINE=gemini

# === Gemini settings (when STT_ENGINE=gemini) ===
GEMINI_API_KEY=YOUR_GEMINI_API_KEY     # Get from https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.0-flash
GEMINI_LANGUAGE=Hebrew

# === Whisper settings (when STT_ENGINE=whisper) ===
WHISPER_MODEL=ivrit-ai/faster-whisper-v2-d4
WHISPER_DEVICE=cpu                     # cpu or cuda
WHISPER_COMPUTE=int8                   # int8, float16, float32
WHISPER_LANGUAGE=he                    # Language code or "auto" for auto-detection
WHISPER_BEAM_SIZE=5
